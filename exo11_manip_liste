noms = ["bob", "alice", "carole", "daniel", "edgar"]
def dothething(names: list) -> list:

    expected = []
    for name in names:
        majuscule = name.upper() #transformer en majuscules
        inverse = majuscule[::-1] #inverser le nom
        expected.append(inverse) 

    return expected
print(dothething(noms))
